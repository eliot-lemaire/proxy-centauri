# ============================================================
# Proxy Centauri — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# Mission Control (Web UI)
# ------------------------------------------------------------

# Port the Mission Control dashboard listens on
MISSION_CONTROL_PORT=8080

# Secret used to sign JWT tokens for dashboard auth
# Generate a strong random value: openssl rand -hex 32
MISSION_CONTROL_SECRET=


# ------------------------------------------------------------
# The Oracle (AI Engine)
# ------------------------------------------------------------

# AI provider to use: claude | openai
ORACLE_PROVIDER=claude

# API key for the selected provider
# Claude:  https://console.anthropic.com/settings/keys
# OpenAI:  https://platform.openai.com/api-keys
ORACLE_API_KEY=


# ------------------------------------------------------------
# Data Storage
# ------------------------------------------------------------

# Path to the SQLite metrics database (inside the container)
METRICS_DB_PATH=/data/metrics.db

# Path to the TLS certificate cache (Let's Encrypt / autocert)
CERTS_PATH=/data/certs

# Path to the Stellar Log output directory
LOGS_PATH=/data/logs


# ------------------------------------------------------------
# TLS / Stellar Encryption
# ------------------------------------------------------------

# Email address used for Let's Encrypt certificate registration
# Required when any Jump Gate uses tls: auto
ACME_EMAIL=


# ------------------------------------------------------------
# Advanced (optional — safe to leave as defaults)
# ------------------------------------------------------------

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Set to true to enable Prometheus metrics endpoint (/metrics)
METRICS_ENABLED=true
